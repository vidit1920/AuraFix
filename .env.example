# Copy this file to .env and fill in your real key.
# Get a free Gemini API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key-here

# Which Gemini model to use by default. Flash is the free-tier workhorse.
# Options: gemini-2.5-flash, gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-flash

# Needed for the PR Agent to create pull requests. Generate a token at:
# https://github.com/settings/tokens (classic token with "repo" scope
# is enough; or a fine-grained token scoped to the repos you'll test
# against). Leave unset if you're not testing PR creation yet.
GITHUB_TOKEN=your-github-token-here
